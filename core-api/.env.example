# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=tripops

# JWT
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-20-chars

# 15 minutes
JWT_ACCESS_TTL=900

# 14 days
JWT_REFRESH_TTL=1209600

# Cookies
REFRESH_COOKIE_NAME=tripops_refresh
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS
FRONTEND_URL=http://localhost:5173
